# ============================================================
# CONFIGURACIÓN - copia este archivo como .env y llena los valores
# ============================================================

# Base de datos MySQL
DATABASE_URL=mysql://USUARIO:CONTRASEÑA@localhost:3306/boutique_pos

# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria)
# Puedes generar una con: openssl rand -hex 64
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria

# Puerto del servidor (Hostinger VPS usualmente usa 3000)
PORT=3000

# Entorno
NODE_ENV=production

# OpenID del usuario administrador principal
# Después de que el dueño se registre por primera vez, obtén su ID de la BD:
# SELECT openId FROM users WHERE email = 'tu@email.com';
# y pon ese valor aquí (será algo como "local_1")
OWNER_OPEN_ID=local_1

# Email del dueño (opcional, para referencia)
OWNER_EMAIL=tu@email.com

# ============================================================
# PAGOS (opcional - solo si usas Stripe)
# ============================================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# ALMACENAMIENTO DE ARCHIVOS (opcional - para imágenes de productos)
# Si no lo configuras, las imágenes no se guardarán
# ============================================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=boutique-pos-files

# ============================================================
# ALMACENAMIENTO LOCAL (imágenes de productos, banners, etc.)
# ============================================================
# Directorio donde se guardarán los archivos subidos
# Si no lo pones, usará la carpeta "uploads/" dentro del proyecto
UPLOADS_DIR=/var/www/boutique-pos/uploads

# URL pública base para acceder a los archivos
# Debe coincidir con la ruta que sirve Nginx o Express
UPLOADS_PUBLIC_URL=/uploads

# ============================================================
# INTELIGENCIA ARTIFICIAL (opcional - solo si usas el chat IA)
# Compatible con OpenAI y cualquier API OpenAI-compatible
# ============================================================
# LLM_API_KEY=sk-...
# LLM_API_URL=https://api.openai.com   # o usa otra API compatible
